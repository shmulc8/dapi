{
  "name": "dapi-cli",
  "version": "1.1.1",
  "description": "CLI debugger for AI agents — attach by PID, auto-context on every stop, multi-session",
  "keywords": [
    "debugger",
    "dap",
    "cli",
    "ai-agent",
    "breakpoint",
    "python",
    "go",
    "javascript",
    "typescript",
    "rust"
  ],
  "type": "module",
  "bin": {
    "dapi": "./bin/dapi.js"
  },
  "files": [
    "bin/",
    "dist/",
    "skills/"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "bun build src/cli.ts src/daemon.ts --outdir dist/src --target node && chmod +x bin/dapi.js",
    "prepublishOnly": "bun run build",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anuk909/dapi.git"
  },
  "license": "MIT"
}
